void Write_Any(unsigned char myChar[])
{
	unsigned short Column;
	Clear_Matrix();
	for(Column=0;Column<8;Column++)
	{
		Write_Byte(Column+1, myChar[Column]);
	}
}

void Write_Char(unsigned char myChar)
{
	unsigned char Column, Start_Byte;
	Clear_Matrix();
	Start_Byte = myChar - 'A';
	for(Column=0;Column<8;Column++)
	{
		Write_Byte(Column+1, Alpha[Start_Byte][Column]);
	}
}

void Write_Num(unsigned char myChar)
{
	unsigned char Column, Start_Byte;
	Clear_Matrix();
	Start_Byte = myChar - '0';
	for(Column=0;Column<8;Column++)
	{
		Write_Byte(Column+1, Num[Start_Byte][Column]);
	}
}
void Write_Mini_Num(unsigned char myChar)
{
	unsigned char Column, Start_Byte;
	Clear_Matrix();
	Start_Byte = myChar - '0';
	for(Column=0;Column<8;Column++)
	{
		Write_Byte(Column+1, Mini_num[Start_Byte][Column]);
	}
}

void Write_Two_Mini_Num(unsigned char myChar)
{
	unsigned char Column, Ten_num, One_num;
	Clear_Matrix();
	Ten_num = (myChar/10)%10;
	One_num = myChar%10;
	for(Column=0;Column<8;Column++)
	{
		Write_Byte(Column+1,
		Mini_num[Ten_num][Column] | (Mini_num[One_num][Column] >> 4));
	}
}

int main()
{
	unsigned char i=0;

	DDRC=0xFF;
	MAX7219_INIT(); // initialize max7219

	while(1)
	{
		// 1) Write_Any: Smile 배열의 모든 패턴 순차 출력
		for(i=0; i<2; i++)
		{
			Write_Any(Smile[i]);
			_delay_ms(500);
		}

		// 2) Write_Char: 알파벳 A-Z 순차 출력
		for(i='A'; i<='Z'; i++)
		{
			Write_Char(i);
			_delay_ms(500);
		}

		// 3) Write_Num: 숫자 0-9 순차 출력
		for(i='0'; i<='9'; i++)
		{
			Write_Num(i);
			_delay_ms(500);
		}

		// 4) Write_Mini_Num: 미니 숫자 0-9 순차 출력
		for(i='0'; i<='9'; i++)
		{
			Write_Mini_Num(i);
			_delay_ms(500);
		}
	}
}
